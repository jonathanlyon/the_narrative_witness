# KIT_API_KEY and KIT_FORM_ID:
# Required in Vercel. Server-only Kit credentials used by /api/subscribe.
KIT_API_KEY=""
KIT_FORM_ID="9530240"

# VITE_SUBSCRIBE_ENDPOINT:
# Optional override. Production defaults to the same-origin /api/subscribe function.
VITE_SUBSCRIBE_ENDPOINT=""

# VITE_KICKSTARTER_PRELAUNCH_URL:
# Optional. Add the official Kickstarter pre-launch URL when it is live.
VITE_KICKSTARTER_PRELAUNCH_URL=""

# VITE_META_PIXEL_ID:
# Optional override. Production currently defaults to the public Pixel ID in src/lib/analytics.ts.
VITE_META_PIXEL_ID="2404031020073363"

# VITE_MIXPANEL_TOKEN:
# Optional override. Production currently defaults to the public project token in src/lib/analytics.ts.
VITE_MIXPANEL_TOKEN="a2d4bf4421347c1afc2250024f7876bb"

# ---------------------------------------------------------------------------
# STORE (Stripe + Lulu) — pre-order chain. Server-only secrets have NO VITE_
# prefix so they never reach the browser. See LAUNCH_NOTES.md for the flips.
# ---------------------------------------------------------------------------

# "preorder" (live default: record + Kit tag, NO printing) or "print"
# (create Lulu print jobs — sandbox testing now, real fulfilment Dec 2026).
FULFILMENT_MODE="preorder"

# Stripe — dashboard.stripe.com (test keys first: sk_test_..., whsec_...)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Lulu Print API — developers.lulu.com (sandbox account for testing)
LULU_CLIENT_KEY=""
LULU_CLIENT_SECRET=""
LULU_ENV="sandbox"            # "sandbox" while testing, "production" to go live
LULU_TOKEN_URL=""             # optional override if the realm URL differs
LULU_CONTACT_EMAIL="orders@thenarrativewitness.com"
LULU_POD_PACKAGE_ID=""        # premium B&W SKU at fulfilment; blank = standard 6x9 B&W

# Print-ready PDFs — URLs Lulu can fetch at print time. NOT in /public
# (that gives the interior away). Storage bucket with unguessable/signed URLs.
PAPERBACK_INTERIOR_URL=""
PAPERBACK_COVER_URL=""
